# ===================== Python =====================
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# ===================== Secrets / env =====================
.env
*.env
.env.*

# ============================================================
# MIMIC-IV / PHI — credentialed PhysioNet data. NEVER commit.
# (matched by directory name, robust to relocation)
# ============================================================
ckd_samples/
lookup_tables/
patient_db/
NotesDB/

# Patient-derived data formats (defense-in-depth blanket rules).
# There is no benign file of these types in this codebase; if a
# truly non-PHI file ever needs sharing, force-add it explicitly.
*.csv
*.parquet
*.pkl
*.npy
*_chunks.jsonl

# EDA / analysis notebooks — output cells may embed patient data.
# Review and clear outputs before sharing any notebook.
*.ipynb

# Schema / table-description metadata (e.g. sql_agent/metadata.yaml) — keep local.
*.yaml
*.yml

# ============================================================
# Agent run outputs / transcripts — contain patient data
# ============================================================
runs/
logs/

# ===================== Logs / temp =====================
*.log
*.err
*.out
*.bak

# ===================== Editor / OS =====================
.vscode/
.idea/
.DS_Store
